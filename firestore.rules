rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function myEmail() {
      return signedIn() && request.auth.token.email is string
        ? request.auth.token.email
        : '';
    }

    function hasUserDoc() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(myUid()));
    }

    function currentUserDoc() {
      return hasUserDoc()
        ? get(/databases/$(database)/documents/users/$(myUid())).data
        : null;
    }

    function userRole() {
      return hasUserDoc()
        ? currentUserDoc().role
        : null;
    }

    function currentUserResidentId() {
      return hasUserDoc() && currentUserDoc().residentId is string
        ? currentUserDoc().residentId
        : '';
    }

    function isEmployeeEmailFallback() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@employee[.]layaresident[.]local$');
    }

    function isAdminLike() {
      return userRole() in ['admin', 'manager', 'staff'] || isEmployeeEmailFallback();
    }

    function validSelfUserCreate(uid) {
      return signedIn()
        && myUid() == uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'role',
          'employeeId',
          'memberId',
          'memberCode',
          'publicCardCode',
          'residentId',
          'isActive',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ])
        && request.resource.data.role in ['resident', 'staff']
        && (!request.resource.data.keys().hasAny(['uid']) || request.resource.data.uid == myUid());
    }

    function validSelfUserUpdate(uid) {
      return signedIn()
        && myUid() == uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'role',
          'employeeId',
          'memberId',
          'memberCode',
          'publicCardCode',
          'residentId',
          'isActive',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ])
        && request.resource.data.role == resource.data.role
        && request.resource.data.employeeId == resource.data.employeeId
        && request.resource.data.residentId == resource.data.residentId
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function memberOwnedByCurrentUserDoc() {
      return signedIn() && resource.data.authUid == myUid();
    }

    function memberOwnedByCurrentUser(memberId) {
      return signedIn()
        && exists(/databases/$(database)/documents/members/$(memberId))
        && get(/databases/$(database)/documents/members/$(memberId)).data.authUid == myUid();
    }

    function residentDocMatchesCurrentUser(data) {
      return signedIn() && (
        (data.authUid is string && data.authUid == myUid())
        || (data.linkedUserUid is string && data.linkedUserUid == myUid())
        || (currentUserResidentId() != '' && currentUserResidentId() == data.id)
        || (data.loginEmail is string && data.loginEmail == myEmail())
      );
    }

    function residentOwnedByCurrentUserDoc() {
      return signedIn() && (
        (resource.data.authUid is string && resource.data.authUid == myUid())
        || (resource.data.linkedUserUid is string && resource.data.linkedUserUid == myUid())
        || (currentUserResidentId() != '' && currentUserResidentId() == resource.data.id)
        || (resource.data.loginEmail is string && resource.data.loginEmail == myEmail())
      );
    }

    function residentOwnedByCurrentUser(residentId) {
      return signedIn()
        && exists(/databases/$(database)/documents/residents/$(residentId))
        && (
          (get(/databases/$(database)/documents/residents/$(residentId)).data.authUid is string && get(/databases/$(database)/documents/residents/$(residentId)).data.authUid == myUid())
          || (get(/databases/$(database)/documents/residents/$(residentId)).data.linkedUserUid is string && get(/databases/$(database)/documents/residents/$(residentId)).data.linkedUserUid == myUid())
          || (currentUserResidentId() != '' && currentUserResidentId() == residentId)
          || (get(/databases/$(database)/documents/residents/$(residentId)).data.loginEmail is string && get(/databases/$(database)/documents/residents/$(residentId)).data.loginEmail == myEmail())
        );
    }


    function residentOwnedByCurrentUserAfter(residentId) {
      return signedIn()
        && existsAfter(/databases/$(database)/documents/residents/$(residentId))
        && (
          (getAfter(/databases/$(database)/documents/residents/$(residentId)).data.authUid is string && getAfter(/databases/$(database)/documents/residents/$(residentId)).data.authUid == myUid())
          || (getAfter(/databases/$(database)/documents/residents/$(residentId)).data.linkedUserUid is string && getAfter(/databases/$(database)/documents/residents/$(residentId)).data.linkedUserUid == myUid())
          || (getAfter(/databases/$(database)/documents/residents/$(residentId)).data.loginEmail is string && getAfter(/databases/$(database)/documents/residents/$(residentId)).data.loginEmail == myEmail())
        );
    }

    function validSelfResidentCreate(residentId) {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'id',
          'memberCode',
          'qrCodeValue',
          'cardNumber',
          'firstName',
          'lastName',
          'displayName',
          'email',
          'loginEmail',
          'loginEmailLower',
          'linkedUserUid',
          'authUid',
          'phone',
          'status',
          'tier',
          'ownerType',
          'primaryUnitCode',
          'unitCodes',
          'notes',
          'totalSpend',
          'inviteCode',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == residentId
        && request.resource.data.authUid == myUid()
        && request.resource.data.linkedUserUid == myUid()
        && request.resource.data.loginEmail == myEmail()
        && request.resource.data.status == 'active'
        && request.resource.data.tier == 'elite_black'
        && request.resource.data.totalSpend == 0;
    }

    function validSelfResidentWalletCreate(residentId) {
      return signedIn()
        && residentOwnedByCurrentUserAfter(residentId)
        && request.resource.data.keys().hasOnly([
          'residentId',
          'currentPoints',
          'pendingPoints',
          'lifetimeEarned',
          'lifetimeRedeemed',
          'updatedAt'
        ])
        && request.resource.data.residentId == residentId
        && request.resource.data.currentPoints == 0
        && request.resource.data.pendingPoints == 0
        && request.resource.data.lifetimeEarned == 0
        && request.resource.data.lifetimeRedeemed == 0;
    }

    function validSelfResidentCardCreate(residentId) {
      return signedIn()
        && residentOwnedByCurrentUserAfter(residentId)
        && request.resource.data.keys().hasOnly([
          'residentId',
          'memberCode',
          'cardNumber',
          'qrCodeValue',
          'status',
          'issuedAt',
          'updatedAt'
        ])
        && request.resource.data.residentId == residentId
        && request.resource.data.status == 'active';
    }

    function validSelfInviteClaim(code) {
      return signedIn()
        && resource.data.code == code
        && resource.data.status == 'active'
        && (!(resource.data.claimedByUid is string) || resource.data.claimedByUid == '')
        && request.resource.data.keys().hasOnly([
          'code',
          'status',
          'primaryUnitCode',
          'additionalUnitCodes',
          'usageLimit',
          'createdByUid',
          'createdByEmail',
          'createdAt',
          'updatedAt',
          'claimedAt',
          'claimedByUid',
          'claimedByEmail',
          'claimedResidentId'
        ])
        && request.resource.data.code == resource.data.code
        && request.resource.data.primaryUnitCode == resource.data.primaryUnitCode
        && request.resource.data.additionalUnitCodes == resource.data.additionalUnitCodes
        && request.resource.data.usageLimit == resource.data.usageLimit
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.createdByEmail == resource.data.createdByEmail
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.status == 'claimed'
        && request.resource.data.claimedByUid == myUid()
        && request.resource.data.claimedByEmail == myEmail()
        && request.resource.data.claimedResidentId is string
        && residentOwnedByCurrentUserAfter(request.resource.data.claimedResidentId);
    }

    match /users/{uid} {
      allow get: if signedIn() && (myUid() == uid || isAdminLike());
      allow list: if isAdminLike();
      allow create: if validSelfUserCreate(uid) || isAdminLike();
      allow update: if validSelfUserUpdate(uid) || isAdminLike();
      allow delete: if isAdminLike();
    }

    match /members/{memberId} {
      allow get: if isAdminLike() || memberOwnedByCurrentUserDoc();
      allow list: if isAdminLike() || memberOwnedByCurrentUserDoc();
      allow create, update, delete: if isAdminLike();
    }

    match /point_wallets/{memberId} {
      allow get: if isAdminLike() || memberOwnedByCurrentUser(memberId);
      allow list: if isAdminLike() || (signedIn() && memberOwnedByCurrentUser(memberId));
      allow create, update: if isAdminLike();
      allow delete: if false;
    }

    match /point_transactions/{txId} {
      allow get, list: if isAdminLike() || (signedIn() && resource.data.memberId is string && memberOwnedByCurrentUser(resource.data.memberId));
      allow create: if isAdminLike();
      allow update, delete: if false;
    }

    match /spend_transactions/{txId} {
      allow get, list: if isAdminLike() || (signedIn() && resource.data.memberId is string && memberOwnedByCurrentUser(resource.data.memberId));
      allow create, update: if isAdminLike();
      allow delete: if false;
    }

    match /redemptions/{docId} {
      allow get, list: if isAdminLike() || (signedIn() && resource.data.requestedByUid == myUid());
      allow create: if signedIn() && request.resource.data.requestedByUid == myUid();
      allow update: if isAdminLike() || (signedIn() && resource.data.requestedByUid == myUid());
      allow delete: if isAdminLike();
    }

    match /news/{docId} {
      allow read: if true;
      allow write: if isAdminLike();
    }

    match /promotions/{docId} {
      allow read: if true;
      allow write: if isAdminLike();
    }

    match /benefits/{docId} {
      allow read: if true;
      allow write: if isAdminLike();
    }

    match /reward_catalog/{docId} {
      allow read: if true;
      allow write: if isAdminLike();
    }

    match /app_settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdminLike();
    }

    match /residents/{residentId} {
      allow get: if isAdminLike() || residentOwnedByCurrentUserDoc();
      allow list: if isAdminLike();
      allow create: if isAdminLike() || validSelfResidentCreate(residentId);
      allow update, delete: if isAdminLike();
    }

    match /resident_wallets/{residentId} {
      allow get: if isAdminLike() || residentOwnedByCurrentUser(residentId);
      allow list: if isAdminLike();
      allow create: if isAdminLike() || validSelfResidentWalletCreate(residentId);
      allow update: if isAdminLike();
      allow delete: if isAdminLike();
    }

    match /resident_cards/{residentId} {
      allow get: if isAdminLike() || residentOwnedByCurrentUser(residentId);
      allow list: if isAdminLike();
      allow create: if isAdminLike() || validSelfResidentCardCreate(residentId);
      allow update: if isAdminLike();
      allow delete: if isAdminLike();
    }

    match /resident_invite_codes/{code} {
      allow get: if true;
      allow list: if isAdminLike();
      allow create, delete: if isAdminLike();
      allow update: if isAdminLike() || validSelfInviteClaim(code);
    }

    match /resident_point_transactions/{transactionId} {
      allow get, list: if isAdminLike() || (signedIn() && resource.data.residentId is string && residentOwnedByCurrentUser(resource.data.residentId));
      allow create: if isAdminLike();
      allow update, delete: if false;
    }

    match /resident_activity_logs/{logId} {
      allow get, list: if isAdminLike();
      allow create: if isAdminLike();
      allow update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read, write: if isAdminLike();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
