rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return signedIn() && me().data.role != null ? me().data.role : null;
    }

    function isAdmin() {
      return myRole() in ['admin', 'manager'];
    }

    function isStaff() {
      return myRole() in ['staff', 'manager', 'admin'];
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /residents/{residentId} {
      allow read: if signedIn() && (
        resource.data.userUid == request.auth.uid ||
        isStaff()
      );
      allow create, update: if isStaff();
      allow delete: if false;
    }

    match /benefits/{benefitId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /pointTransactions/{transactionId} {
      allow read: if signedIn() && (
        resource.data.userUid == request.auth.uid ||
        isStaff()
      );
      allow create: if isStaff();
      allow update, delete: if false;
    }

    match /outlets/{outletId} {
      allow read: if signedIn();
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }
  }
}
