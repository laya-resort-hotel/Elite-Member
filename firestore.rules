rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/staff_users/$(request.auth.uid));
    }

    function currentResidentAuthDoc() {
      return get(/databases/$(database)/documents/resident_auth_profiles/$(request.auth.uid));
    }

    function isStaff() {
      return signedIn()
        && exists(/databases/$(database)/documents/staff_users/$(request.auth.uid));
    }

    function isRole(role) {
      return isStaff() && currentUserDoc().data.role == role;
    }

    function isSupervisorOrAbove() {
      return isStaff() && (
        currentUserDoc().data.role == 'supervisor' ||
        currentUserDoc().data.role == 'manager' ||
        currentUserDoc().data.role == 'admin'
      );
    }

    function isManagerOrAbove() {
      return isStaff() && (
        currentUserDoc().data.role == 'manager' ||
        currentUserDoc().data.role == 'admin'
      );
    }

    function isAdmin() {
      return isRole('admin');
    }

    function isOwnResidentDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/resident_auth_profiles/$(request.auth.uid))
        && currentResidentAuthDoc().data.memberId == resource.data.memberId;
    }

    function isCreatingOwnResidentDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/resident_auth_profiles/$(request.auth.uid))
        && currentResidentAuthDoc().data.memberId == request.resource.data.memberId;
    }

    function validPublishStatus() {
      return request.resource.data.status in ['draft', 'published', 'scheduled', 'expired', 'archived'];
    }

    function validNewsPayload() {
      return request.resource.data.title is string
        && request.resource.data.summary is string
        && request.resource.data.coverImage is string
        && request.resource.data.publishDate is string
        && request.resource.data.status is string
        && validPublishStatus();
    }

    function validPromotionPayload() {
      return request.resource.data.title is string
        && request.resource.data.outlet is string
        && request.resource.data.summary is string
        && request.resource.data.description is string
        && request.resource.data.bannerImage is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string
        && request.resource.data.status is string
        && validPublishStatus();
    }

    function validBenefitPayload() {
      return request.resource.data.title is string
        && request.resource.data.category is string
        && request.resource.data.shortDescription is string
        && request.resource.data.fullDescription is string
        && request.resource.data.status in ['active', 'inactive']
        && request.resource.data.sortOrder is int;
    }

    match /resident_auth_profiles/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /staff_users/{uid} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /resident_members/{docId} {
      allow read: if isStaff() || isOwnResidentDoc();
      allow create: if isAdmin() || isCreatingOwnResidentDoc();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /resident_transactions/{docId} {
      allow read: if isStaff() || (
        signedIn()
        && exists(/databases/$(database)/documents/resident_auth_profiles/$(request.auth.uid))
        && currentResidentAuthDoc().data.memberId == resource.data.memberId
      );
      allow create: if isStaff()
        && request.resource.data.memberId is string
        && request.resource.data.outletName is string
        && request.resource.data.amount is number
        && request.resource.data.pointsEarned is int
        && request.resource.data.billNumber is string
        && request.resource.data.status in ['earned', 'used', 'adjusted', 'voided'];
      allow update: if isSupervisorOrAbove();
      allow delete: if false;
    }

    match /point_adjustments/{docId} {
      allow read: if isSupervisorOrAbove();
      allow create: if isSupervisorOrAbove();
      allow update: if isManagerOrAbove();
      allow delete: if false;
    }

    match /resident_news/{docId} {
      allow read: if resource.data.status == 'published' || isStaff();
      allow create: if isManagerOrAbove() && validNewsPayload();
      allow update: if isManagerOrAbove() && validNewsPayload();
      allow delete: if isAdmin();
    }

    match /resident_promotions/{docId} {
      allow read: if resource.data.status == 'published' || isStaff();
      allow create: if isManagerOrAbove() && validPromotionPayload();
      allow update: if isManagerOrAbove() && validPromotionPayload();
      allow delete: if isAdmin();
    }

    match /resident_benefits/{docId} {
      allow read: if resource.data.status == 'active' || isStaff();
      allow create: if isManagerOrAbove() && validBenefitPayload();
      allow update: if isManagerOrAbove() && validBenefitPayload();
      allow delete: if isAdmin();
    }

    match /audit_logs/{docId} {
      allow read: if isManagerOrAbove();
      allow create: if isStaff();
      allow update, delete: if false;
    }
  }
}
